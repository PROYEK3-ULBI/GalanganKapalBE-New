# ============================================
# SIMS Backend Environment Variables
# Copy this file to .env and fill in actual values
# ============================================

# Server
APP_ENV=development
APP_PORT=8080

# CORS - frontend origin (Vite default 5173)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Database - Supabase Transaction Pooler (port 6543) for app runtime
# Get from: Supabase Dashboard > Project Settings > Database > Connection string > Transaction pooler
# Append ?default_query_exec_mode=exec for pgx compatibility with PgBouncer transaction mode
DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?default_query_exec_mode=exec

# Database - Supabase Session Pooler (port 5432) for migrations only
# Get from: Supabase Dashboard > Project Settings > Database > Connection string > Session pooler
DATABASE_MIGRATION_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# JWT - generate with: openssl rand -base64 32
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRY_HOURS=24
